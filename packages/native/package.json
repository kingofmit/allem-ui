{
  "name": "@allem-ui/native",
  "version": "0.0.3",
  "description": "React Native component library for Allem UI — 44 components with NativeWind",
  "license": "MIT",
  "author": "Ahmed Allem (https://kingallem.com)",
  "source": "./src/index.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@allem-ui/theme": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.73.0",
    "nativewind": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@gorhom/bottom-sheet": {
      "optional": true
    },
    "expo-haptics": {
      "optional": true
    },
    "react-native-gesture-handler": {
      "optional": true
    },
    "react-native-reanimated": {
      "optional": true
    },
    "@react-native-community/slider": {
      "optional": true
    }
  },
  "keywords": [
    "allem-ui",
    "react-native",
    "nativewind",
    "ui-library",
    "components",
    "expo",
    "mobile",
    "tailwind"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kingofmit/allem-ui.git",
    "directory": "packages/native"
  }
}
