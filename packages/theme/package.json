{
  "name": "@allem-ui/theme",
  "version": "0.0.2",
  "description": "Theming engine and Tailwind CSS preset for Allem UI",
  "license": "MIT",
  "author": "Ahmed Allem (https://kingallem.com)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.mjs",
      "require": "./dist/preset.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "tailwindcss": ">=4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kingofmit/allem-ui.git",
    "directory": "packages/theme"
  },
  "keywords": [
    "allem-ui",
    "theme",
    "tailwind",
    "css",
    "design-system"
  ],
  "publishConfig": {
    "access": "public"
  }
}
