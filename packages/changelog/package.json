    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "@allem-ui/react": ">=0.0.1",
    "@allem-ui/theme": ">=0.0.1",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kingofmit/allem-ui.git",
    "directory": "packages/changelog"
  },
  "keywords": ["allem-ui", "changelog", "timeline", "release-notes", "react", "components"],
