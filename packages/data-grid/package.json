{
  "name": "@allem-ui/data-grid",
  "version": "0.0.4",
  "description": "Advanced data grid with sorting, filtering, and virtualization for Allem UI",
  "license": "MIT",
  "author": "Ahmed Allem (https://kingallem.com)",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "@allem-ui/react": ">=0.0.4",
    "@allem-ui/theme": ">=0.0.3",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kingofmit/allem-ui.git",
    "directory": "packages/data-grid"
  },
  "keywords": [
    "allem-ui",
    "data-grid",
    "table",
    "sorting",
    "filtering",
    "react",
    "tanstack"
